{
	"name": "jcodigital/jcore-update",
	"description": "Composer-installable WordPress plugin updater integration for the JCORE Update API.",
	"type": "library",
	"require": {
		"php": "^8.1",
		"ext-json": "*"
	},
	"autoload": {
		"psr-4": {
			"Jcore\\Update\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Jcore\\Update\\Tests\\": "tests/"
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"squizlabs/php_codesniffer": "^3.9",
		"wp-coding-standards/wpcs": "^3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"scripts": {
		"test": "phpunit",
		"lint": "phpcs",
		"fix": "phpcbf"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
